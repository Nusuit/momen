# App runtime (safe placeholder values)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Local web runtime convenience
FLUTTER_WEB_HOST=http://localhost
FLUTTER_WEB_PORT=1708
FLUTTER_WEB_URL=http://localhost:1708

# Optional database connection details (for local admin scripts only)
SUPABASE_DB_HOST=YOUR_POOLER_HOST
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=YOUR_DB_USER
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
SUPABASE_DB_CONNECTION_STRING=postgresql://YOUR_DB_USER:YOUR_URL_ENCODED_PASSWORD@YOUR_POOLER_HOST:5432/postgres

# Backend-only secrets (never ship to app client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# OAuth (Google Cloud / Supabase provider)
GOOGLE_OAUTH_WEB_CLIENT_ID=YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID
GOOGLE_OAUTH_WEB_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_WEB_CLIENT_SECRET

# OTP email sender (backend-only)
OTP_EMAIL_ADDRESS=YOUR_GMAIL_ADDRESS
OTP_GMAIL_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
